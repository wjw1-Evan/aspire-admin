<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <config>
    <!-- 并发下载数（默认 16，提高并行度加快包恢复） -->
    <add key="maxHttpRequestsPerSource" value="32" />
    <!-- HTTP 请求超时（秒） -->
    <add key="httpClientSendTimeout" value="300" />
  </config>
</configuration>
