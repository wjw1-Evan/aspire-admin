{
  "name": "platform-admin",
  "version": "1.0.0",
  "private": true,
  "description": "Aspire Admin 管理后台前端项目",
  "repository": "https://github.com/wjw1-Evan/aspire-admin.git",
  "scripts": {
    "clean": "rm -rf src/.umi src/.umi-production node_modules/.cache",
    "preanalyze": "npm run clean",
    "prebuild": "npm run clean",
    "predev": "npm run clean",
    "prestart": "npm run clean",
    "analyze": "cross-env ANALYZE=1 max build",
    "build": "max build",
    "dev": "npm run start:dev",
    "lint": "npm run biome:lint; npm run tsc",
    "biome:lint": "biome lint",
    "biome": "biome check --write",
    "postinstall": "max setup",
    "preview": "npm run build && max preview --port 8000",
    "start": "cross-env UMI_ENV=dev max dev",
    "start:dev": "cross-env REACT_APP_ENV=dev UMI_ENV=dev max dev",
    "start:pre": "cross-env REACT_APP_ENV=pre UMI_ENV=dev max dev",
    "start:test": "cross-env REACT_APP_ENV=test UMI_ENV=dev max dev",
    "tsc": "tsc --noEmit",
    "outdated": "npm outdated",
    "install-package": "npm install",
    "split-locales": "node scripts/split-locales.js"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@ant-design/pro-components": "^3.1.12-0",
    "@ant-design/x": "^2.7.0",
    "@ant-design/x-markdown": "^2.7.0",
    "@ant-design/x-sdk": "^2.7.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@rc-component/util": "^1.10.1",
    "@tanstack/react-query": "^5.100.10",
    "@types/dagre": "^0.7.54",
    "@types/react-grid-layout": "^2.1.0",
    "ahooks": "^3.9.7",
    "antd": "^6.3.7",
    "antd-style": "^4.1.0",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "jsencrypt": "^3.5.4",
    "mammoth": "^1.12.0",
    "marked": "^18.0.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-grid-layout": "^2.2.3",
    "react-resizable": "^3.1.3",
    "reactflow": "^11.11.4",
    "sm-crypto": "^0.4.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sm-crypto": "^0.3.4",
    "@umijs/lint": "^4.6.53",
    "@umijs/max": "^4.6.53",
    "@umijs/request-record": "^1.1.4",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
